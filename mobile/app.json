{
  "expo": {
    "name": "AI 투자 어시스턴트",
    "slug": "aijusik",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.personal.aijusik"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.personal.aijusik",
      "newArchEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "scheme": "aijusik",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4b0b0ac1-7989-462c-bbf3-99e8cbf114d2"
      }
    }
  }
}
